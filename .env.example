# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Database
DB_URL=jdbc:postgresql://localhost:5432/academate_dev
DB_USER=postgres
DB_PASS=postgres

# Server
SERVER_PORT=8080

# JWT (min 256-bit / 32 chars)
JWT_SECRET=changeme-please-use-at-least-256-bit-secret-in-production-environment

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# SMTP (dev: use MailHog on port 1025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_AUTH=false
SMTP_STARTTLS=false

# AWS S3
AWS_REGION=eu-central-1
AWS_S3_BUCKET=academate-dev
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# AI Service (Python RAG)
AI_SERVICE_URL=http://localhost:8000
